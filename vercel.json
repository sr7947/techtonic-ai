{
  "crons": [
    {
      "path": "/api/sync-news",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/telegram-monitor",
      "schedule": "0 */4 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
